[
  {
    "log": {
      "loglevel": "warning"
    },
    "inbounds": [
      {
        "listen": "127.0.0.1",
        "port": 10810,
        "protocol": "http",
        "settings": {
          "timeout": 0,
          "allowTransparent": false,
          "userLevel": 0
        },
        "tag": "http-in"
      }
    ],
    "outbounds": [
      {
        "protocol": "vless",
        "settings": {
          "vnext": [
            {
              "address": "104.18.3.150",
              "port": 443,
              "users": [
                {
                  "id": "fc625795-792d-4d9d-9d38-bffe59467d2d",
                  "encryption": "none",
                  "flow": ""
                }
              ]
            }
          ]
        },
        "streamSettings": {
          "network": "ws",
          "security": "tls",
          "tlsSettings": {
            "serverName": "daluan.eu.org",
            "allowInsecure": true,
            "fingerprint": "chrome",
            "alpn": [
              "h2",
              "http/1.1"
            ]
          },
          "wsSettings": {
            "path": "/",
            "headers": {
              "Host": "daluan.eu.org"
            }
          }
        },
        "tag": "proxy"
      },
      {
        "protocol": "freedom",
        "tag": "direct"
      }
    ],
    "routing": {
      "domainStrategy": "IPIfNonMatch",
      "rules": [
        {
          "type": "field",
          "ip": [
            "geoip:private"
          ],
          "outboundTag": "direct"
        }
      ]
    }
  }
